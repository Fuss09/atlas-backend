# ──────────────────────────────────────────────────────────────────────────────
# Atlas - Environment Variables
# Copier ce fichier vers .env et remplir les valeurs
# NE JAMAIS committer le .env en production
# ──────────────────────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000"]

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlas
POSTGRES_ECHO=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=atlas
RABBITMQ_PASSWORD=atlas

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlas_neo4j

# JWT — CHANGER EN PRODUCTION (min 32 caractères)
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Feature Flags
FEATURE_NEO4J_ENABLED=true
FEATURE_RABBITMQ_ENABLED=true

# ── Découverte (collectors) ──────────────────────────────────────────────────
# SEC EDGAR et autres APIs publiques exigent un contact réel dans le User-Agent.
# Mets ta vraie adresse avant tout run de découverte réel.
COLLECTOR_CONTACT_EMAIL=your-email@example.com
